{
  "name": "bradreardon-studio",
  "version": "1.0.0",
  "description": "Local photo management tool for bradreardon.studio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "bradreardon.studio",
    "productName": "Brad Reardon Studio",
    "win": {
      "icon": "icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "files": [
      "main.js",
      "index.html",
      "icon.ico",
      "package.json",
      "node_modules/**/*"
    ]
  }
}
