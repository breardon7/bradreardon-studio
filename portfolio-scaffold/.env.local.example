# ── Site ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bradreardon.studio

# ── Email (Resend) ────────────────────────────────────────────────
# Get your key at resend.com — free tier: 100 emails/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (add when print shop goes live) ────────────────────────
# At launch, use manual invoicing via Stripe Payment Links (no code needed)
# When volume grows, add Stripe Checkout:
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AWS S3 (optional — only needed for digital file delivery) ─────
# Not required for physical print fulfilment
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=bradreardon-prints
